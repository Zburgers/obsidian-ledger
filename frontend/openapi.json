  "components": {
    "schemas": {
      "CategoryItem": {
        "properties": {
          "category": {
            "type": "string",
            "title": "Category"
          },
          "total": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Total"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          }
        },
        "type": "object",
        "required": [
          "category",
          "total",
          "count"
        ],
        "title": "CategoryItem"
      },
      "CategoryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/CategoryItem"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "items"
        ],
        "title": "CategoryResponse"
      },
      "ComparisonResponse": {
        "properties": {
          "period_a": {
            "type": "string",
            "title": "Period A"
          },
          "period_b": {
            "type": "string",
            "title": "Period B"
          },
          "totals_a": {
            "$ref": "#/components/schemas/ComparisonTotals"
          },
          "totals_b": {
            "$ref": "#/components/schemas/ComparisonTotals"
          },
          "income_delta": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Income Delta"
          },
          "expense_delta": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Expense Delta"
          },
          "net_delta": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Net Delta"
          }
        },
        "type": "object",
        "required": [
          "period_a",
          "period_b",
          "totals_a",
          "totals_b",
          "income_delta",
          "expense_delta",
          "net_delta"
        ],
        "title": "ComparisonResponse"
      },
      "ComparisonTotals": {
        "properties": {
          "income": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Income"
          },
          "expense": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Expense"
